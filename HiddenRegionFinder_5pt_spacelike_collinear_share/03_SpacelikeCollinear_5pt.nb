Cell[CellGroupData[{

Cell["Current preselected 5-point scan results", "Section",ExpressionUUID->"8390067b-3951-4d72-ac00-54a710beace3"],

Cell["\<\
Collaborator-facing summary of the current polynomial HRF scan. These cells \
read the saved outputs from HRF_RunPreselected5ptScan.wl; they do not run \
HRF. Boundary ZeroVars are diagnostic strata where HRF found a hidden region. \
The graph catalogue deliberately draws the original topologies, because those \
are the objects passed onward to HRF.\
\>", "Text",ExpressionUUID->"7a204557-6eb0-430e-a478-3fd7ba4984eb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$HRFQuietReports", "=", "True"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], 
      ",", "\"\<HRF_Example03PreselectedResults.wl\>\""}], "}"}], "]"}], 
   "]"}], ";"}]], "Input",
 CellLabel->"In[15]:=",ExpressionUUID->"ab4ce62d-0ce3-4a89-aa28-115e26a85a90"],

