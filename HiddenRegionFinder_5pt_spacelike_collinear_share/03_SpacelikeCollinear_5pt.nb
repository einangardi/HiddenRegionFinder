Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"HiddenRegionQ\"\>", "\[Rule]", "True"}], ",", 
   RowBox[{"\<\"Generators\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x1", " ", "x4"}], "+", 
        RowBox[{"x", " ", "x0", " ", "x5"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "x2"}], "-", "x3", "+", 
        RowBox[{"x2", " ", "z"}]}], ")"}]}], "}"}]}], ",", 
   RowBox[{"\<\"AttemptSummary\"\>", "\[Rule]", 
    RowBox[{"\[LeftAssociation]", 
     RowBox[{
      RowBox[{"\<\"TrialCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"CandidateGeneratorCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"PerGeneratorAdmissibleCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"CandidateUnionPDFAdmissibleCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"ObstructionFindInstanceCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"AdmissibleSLSectorCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"ValidObstructionCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"HiddenRegionWithValidScalingCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"ScalingEvaluatedOnValidTrialsQ\"\>", "\[Rule]", "True"}], ",", 
      RowBox[{"\<\"GeneratorCountHistogram\"\>", "\[Rule]", 
       RowBox[{"\[LeftAssociation]", 
        RowBox[{"1", "\[Rule]", "1"}], "\[RightAssociation]"}]}], ",", 
      RowBox[{"\<\"StopOnFirstValidObstructionQ\"\>", "\[Rule]", "False"}], ",", 
      RowBox[{"\<\"StoppedEarlyOnValidObstructionQ\"\>", "\[Rule]", 
       "False"}]}], "\[RightAssociation]"}]}]}], 
