  TagBox[
   DynamicModuleBox[{TypeSystem`NestedGrid`PackagePrivate`$state$$ = <|
    "InitialData" -> {<|
       "Topology" -> "Seed5pt", "PairIndex" -> 1, "Factor1" -> 
        "x2*(-1 + z) + -x3", "Factor2" -> "x*x0*x5 + x1*x4", "Factor1XDegree" -> 
        1, "Factor2XDegree" -> 2, "FactorizedGenerator" -> 
        "(x1*x4 + x*x0*x5)*(-x2 - x3 + x2*z)", "KinPrefilterQ" -> True, 
        "JointPDFQ" -> True, "DegreeAdmissibleQ" -> True, "F0SupportQ" -> 
        True, "MandelstamLinearQ" -> True, "PairAdmissibleQ" -> True, 
        "ResolverMonomialRank" -> 4, "ChosenByResolverQ" -> True, 
        "RejectionReason" -> "chosen"|>, <|
