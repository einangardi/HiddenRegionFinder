  RowBox[{"$HRFEx03SevenPropBoundaryZeroVars", "=", 
   RowBox[{"{", "x6", "}"}]}], ";", 
  RowBox[{"$HRFEx03RunEightPropBoundaryScanQ", "=", "False"}], ";", 
