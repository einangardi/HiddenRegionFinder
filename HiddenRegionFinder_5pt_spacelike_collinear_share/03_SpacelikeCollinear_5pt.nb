Cell[CellGroupData[{

Cell["Regenerate the current preselected scan outputs", "Section",ExpressionUUID->"8a715e6c-7ecf-4b1e-8ef0-a356b01629c1"],

Cell["\<\
Optional. Run from a fresh kernel if the saved CSV/WL files need to be \
regenerated. Observed wall time on this machine: the 70-topology interior \
scan took a few minutes; the codimension-1/2 boundary scan took about 8 \
minutes. The scans overwrite Preselected5ptHRFScan_interior* and \
Preselected5ptHRFScan_boundary_codim2* outputs.\
\>", "Text",ExpressionUUID->"bad7ec03-59a6-40de-81e6-fd3a67bf535f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";", 
  RowBox[{"$HRFPreselectedRunInteriorQ", "=", "True"}], ";", 
  RowBox[{"$HRFPreselectedRunBoundaryQ", "=", "False"}], ";", 
  RowBox[{
  "$HRFPreselectedOutputPrefix", 
   "=", "\"\<Preselected5ptHRFScan_interior\>\""}], ";", 
  RowBox[{"<<", "\"\<HRF_RunPreselected5ptScan.wl\>\""}], ";"}]], "Input",
 CellLabel->"In[23]:=",ExpressionUUID->"0f223586-abb4-4e25-9711-b94a5f05834c"],

Cell[CellGroupData[{

