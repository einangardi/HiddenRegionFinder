Cell[CellGroupData[{
Cell["Regge-limit 4-point examples", "Title",ExpressionUUID->"abb692ac-6dcc-4cd3-844a-c70eba974ca8"],

Cell["\<\
Ex02: In[1] Regge Crown T23 sanity; boundaries In[3]/In[7] separately on \
Second kernel.\
\>", "Text",ExpressionUUID->"600f0b31-0937-4c37-b89b-2dcad24fb57d"],

Cell["\<\
Kernel \"Second\" (Evaluation > Notebook's Kernel). On open, init prints a \
reminder only. Restart Kernel once manually, then run In[1] onward. Do not \
put RestartKernel in auto-run init cells.\
\>", "Text",ExpressionUUID->"3ed09791-c2f2-4ffb-a041-7d65ab4ffd63"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Print", "[", 
   "\"\<HRF notebook loaded. Before In[1], use Evaluation > Restart Kernel \
once (manual).\>\"", "]"}], ";"}]], "Input",
 InitializationCell->True,
 ShowCellTags->False,
 CellLabel->"init:=",ExpressionUUID->"b7949714-1603-4417-b456-2d37e4586ea8"],

Cell["Setup (core + Crown sanity)", "Section",ExpressionUUID->"20644522-c0c1-4aa1-953d-b05a8b5600dc"],

Cell["\<\
In[1] loads core + Crown Regge sanity on T23 (~10\[AHat]\.80\.9330 s). \
Memory: default deep trim keeps summary tables only; run In[3] and In[7] on \
fresh Second kernels (or use 02a/02b). After Ingredients cells (In[6b], \
In[10e]), run hrfEx02ReleaseScanMemory[] in In[25]. \
$HRFFindObstructionsStopOnFirstAdmissibleQ=False enumerates all admissible \
sets (more RAM); set True if memory is tight.\
\>", "Text",ExpressionUUID->"2cae507a-8fca-4b65-a03c-77fb55143459"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$HRFExample02Report", "=", "True"}], ";", 
  RowBox[{"$HRFScalingReport", "=", "False"}], ";", 
  RowBox[{"$HRFRunEx02InteriorStudiesOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFRunEx02LegacyCrownForwardOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFRunEx02BoundariesOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFRunEx02SuperCrownBoundary", "=", "False"}], ";", 
  RowBox[{"$HRFRunEx02HyperCrownBoundaries", "=", "False"}], ";", 
  RowBox[{"$HRFRunEx02CrownSanityOnLoad", "=", "True"}], ";", 
  RowBox[{"$HRFEx02TrimScanStorageQ", "=", "True"}], ";", 
  RowBox[{"$HRFEx02DeepTrimScanStorageQ", "=", "True"}], ";", 
  RowBox[{"$HRFEx02CrownSanityChannels", "=", 
   RowBox[{"{", "\"\<T23\>\"", "}"}]}], ";", 
  RowBox[{"$HRFFindObstructionsStopOnFirstAdmissibleQ", "=", "False"}], ";", 
  RowBox[{"$HRFCandidateGeneratorSetLimit", "=", "64"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<HiddenRegionFinder.wl\>\""}], "}"}], "]"}], "]"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<HRF_PolynomialCancellationFactors.wl\>\""}], "}"}], "]"}], "]"}], 
  ";", 
  RowBox[{"$HRFPolynomialMaxMonomials", "=", "12"}], ";", 
  RowBox[{"$HRFPolynomialRequireKinematicDomainQ", "=", "False"}], ";", 
  RowBox[{"hrfInstallPolynomialCancellationPatch", "[", "]"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<02_Forward_Regge_2to2_Massless.wl\>\""}], "}"}], "]"}], "]"}], ";", 
  RowBox[{"hrfEx02PostLoadCheck", "[", "]"}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"1c79798c-eda1-4dcd-b4c2-b8a03e810d75"],

Cell["Crown Regge sanity check", "Section",ExpressionUUID->"6e20b578-3541-4769-ae7c-5c07cc319c5e"],

Cell["\<\
Regge Crown interior on T23 (PairSectors MaxGenerators=1 + polynomial). \
Validates Ex02 setup before SuperCrown/HyperCrown. Generators and scaling \
vector per channel row.\
\>", "Text",ExpressionUUID->"8c8d9958-ce1a-43ce-966b-3383e3387a47"],

Cell[BoxData[
 RowBox[{"hrfEx02CrownSanityDisplay", "[", "]"}]], "Input",
