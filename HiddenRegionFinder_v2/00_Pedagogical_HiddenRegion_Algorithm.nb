Cell[CellGroupData[{

Cell["Layer I: From a graph to U, F, and P", "Section",ExpressionUUID->"eb3452ed-6fd5-4d02-9c69-57bc97aa9be2"],

Cell["\<\
The graph input follows the pySecDec convention used throughout the package. \
Internal lines are labelled by masses and endpoint vertices. External lines \
are labelled by momenta and the vertex to which they attach.\
\>", "Text",ExpressionUUID->"d43eb0f6-a9c4-4a74-bdb6-7ad8a66065f5"],

