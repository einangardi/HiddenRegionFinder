Cell[CellGroupData[{

Cell["Layer II: Cancellation factors f_i", "Section",ExpressionUUID->"9237de5b-5a79-4576-a091-bec741733ef3"],

Cell["\<\
The LaTeX notes define cancellation factors as non-monomial factors appearing \
in derivatives of the strict leading polynomial F0, or, in the extended \
version, in coefficients of independent kinematic structures inside those \
derivatives. The package implements this distinction by derivativeFactors and \
derivativeFactorsExtended.\
\>", "Text",ExpressionUUID->"3c64710c-82ae-4b26-9078-78d9db3dda61"],

Cell["\<\
Toy example: use a simple polynomial whose derivative with respect to x4 \
contains two binomial factors. This is not a physical graph; it is only a \
transparent algebraic test of the factor/generator/obstruction machinery.\
\>", "Text",ExpressionUUID->"daab650d-84c6-4a06-9d2c-ac6b2c0bb98c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"toyVars", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
    "x0", ",", " ", "x1", ",", " ", "x2", ",", " ", "x3", ",", " ", "x4"}], 
    "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"toyKinVars", " ", "=", " ", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"toyKinAssumptions", " ", "=", " ", "True"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"toyF0", " ", "=", " ", 
    RowBox[{"Expand", "[", 
     RowBox[{
      RowBox[{"x4", " ", 
       RowBox[{"(", 
        RowBox[{"x0", " ", "-", " ", "x1"}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"x2", " ", "-", " ", "x3"}], ")"}]}], " ", "+", " ", 
      RowBox[{"x0", " ", "x2"}]}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"<|", "\n", "  ", 
  RowBox[{
   RowBox[{"\"\<F0\>\"", " ", "->", " ", "toyF0"}], ",", "\n", "  ", 
   RowBox[{"\"\<DerivativeFactors\>\"", " ", "->", " ", 
    RowBox[{"derivativeFactors", "[", 
     RowBox[{"toyF0", ",", " ", "toyVars"}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<SafeCancellationFactors\>\"", " ", "->", " ", 
    RowBox[{
     RowBox[{"safeCancellationFactors", "[", 
      RowBox[{
      "toyF0", ",", " ", "toyVars", ",", " ", "toyKinAssumptions", ",", " ", 
       "toyKinVars"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", "|>"}]}], "Input",ExpressionUUI\
D->"d57d6e75-a1fe-4fc9-816e-7b4cdd53f849"],

Cell["\<\
The package keeps only binomial factors that pass positiveCompatibleQ. \
Internally this uses Reduce with x_e>0 and the chosen kinematic assumptions.\
\>", "Text",ExpressionUUID->"2bc99fc8-9f61-43ef-a2fe-17b3bf8da7b9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"factorData", " ", "=", " ", 
   RowBox[{"safeCancellationFactors", "[", 
    RowBox[{
    "toyF0", ",", " ", "toyVars", ",", " ", "toyKinAssumptions", ",", " ", 
     "toyKinVars"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"toySafeFactors", " ", "=", " ", 
   RowBox[{"factorData", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"AssociationThread", "[", 
  RowBox[{"toySafeFactors", ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"positiveCompatibleQ", "[", 
      RowBox[{
      "#", ",", " ", "toyVars", ",", " ", "toyKinAssumptions", ",", " ", 
       "toyKinVars"}], "]"}], " ", "&"}], " ", "/@", " ", 
    "toySafeFactors"}]}], "]"}]}], "Input",ExpressionUUID->"fae4ff32-f2af-\
4f40-a6e6-e8ed7a3531e3"],

Cell["\<\
Important implementation audit: the current production routine tests \
individual factors for positivity. The stricter simultaneous-admissibility \
condition for a subset S is included here as an audit helper, but it is not \
currently used as a hard gate in findObstructions.\
\>", "Text",ExpressionUUID->"fc454970-0eb1-4390-9aa7-c75e74860d8f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "hrfAdmissibleSubsetQ", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"hrfAdmissibleSubsetQ", "[", 
     RowBox[{
     "S_", ",", " ", "vars_", ",", " ", "kinAssumptions_", ",", " ", 
      "kinVars_"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"Reduce", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"kinAssumptions", " ", "&&", " ", 
        RowBox[{"And", " ", "@@", " ", 
         RowBox[{"Thread", "[", 
          RowBox[{"vars", " ", ">", " ", "0"}], "]"}]}], " ", "&&", " ", 
        RowBox[{"And", " ", "@@", " ", 
         RowBox[{"Thread", "[", 
          RowBox[{"S", " ", "==", " ", "0"}], "]"}]}]}], ",", "\n", "  ", 
       RowBox[{"Join", "[", 
        RowBox[{"vars", ",", " ", "kinVars"}], "]"}], ",", " ", "Reals"}], 
      "\n", "]"}], " ", "=!=", " ", "False"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"Subsets", "[", 
   RowBox[{"toySafeFactors", ",", " ", 
    RowBox[{"{", 
     RowBox[{"1", ",", " ", 
      RowBox[{"Length", "[", "toySafeFactors", "]"}]}], "}"}]}], "]"}], " ", "/.",
   " ", 
  RowBox[{"S_List", " ", ":>", " ", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<Subset\>\"", " ", "->", " ", "S"}], ",", " ", 
     RowBox[{"\"\<SimultaneouslyAdmissibleQ\>\"", " ", "->", " ", 
      RowBox[{"hrfAdmissibleSubsetQ", "[", 
       RowBox[{
       "S", ",", " ", "toyVars", ",", " ", "toyKinAssumptions", ",", " ", 
        "toyKinVars"}], "]"}]}]}], "|>"}]}]}]}], "Input",ExpressionUUID->\
"2ba41796-014f-40d1-8cb5-bb9070bc3e97"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Layer III: Generator products g_k and the cancellation ideal", "Section",ExpressionUUID->"fa9c23b3-a13f-4923-8cd1-534e166cba6c"],

Cell["\<\
The generators of the cancellation ideal are not the individual factors f_i. \
They are products of factors, g_k=Product[f_i, {i in S_k}], as in the current \
LaTeX notes. The package can use a single full product or scan pair-sector \
products.\
\>", "Text",ExpressionUUID->"53475ef9-19d3-4de4-be81-32fc69614a75"],

Cell[BoxData[
 RowBox[{"<|", "\n", "  ", 
  RowBox[{
   RowBox[{"\"\<SafeFactors\>\"", " ", "->", " ", "toySafeFactors"}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<PairSectorGenerators\>\"", " ", "->", " ", 
    RowBox[{"pairSectorGenerators", "[", "toySafeFactors", "]"}]}], ",", "\n",
    "  ", 
   RowBox[{"\"\<CandidateGeneratorSets_SingleProduct\>\"", " ", "->", " ", 
    RowBox[{"candidateGeneratorSets", "[", "toySafeFactors", "]"}]}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<CandidateGeneratorSets_Diagnostic\>\"", " ", "->", " ", 
    RowBox[{"candidateGeneratorSetsDiagnostic", "[", 
     RowBox[{"toySafeFactors", ",", " ", "2"}], "]"}]}]}], "\n", 
  "|>"}]], "Input",ExpressionUUID->"5bb25052-5390-4d39-956c-da764d3a4b73"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Layer IV: Obstruction as a remainder after division by generator products\
\>", "Section",ExpressionUUID->"af7dea1a-b14f-4a2a-bba3-4a31b2615397"],

Cell["\<\
For a chosen generator set G, obstructionByOriginalTermsGeneral searches for \
a subset of original monomials of F0 whose removal makes the remainder lie in \
the ideal <G>. The implementation introduces binary variables b_i selecting \
obstruction monomials and computes PolynomialReduce[F0 - Sum[b_i m_i], G, \
allVars][[2]]. It then imposes that all coefficients of this remainder \
vanish, with b_i in {0,1}.\
\>", "Text",ExpressionUUID->"671498c1-e7ab-4f9b-a01e-ee41af6c3e51"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"toyGenerators", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"Times", " ", "@@", " ", "toySafeFactors"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"toyObs", " ", "=", " ", 
   RowBox[{"obstructionByOriginalTermsGeneral", "[", 
    RowBox[{
    "toyF0", ",", " ", "toyGenerators", ",", " ", "toyVars", ",", " ", 
     "toyKinVars", ",", " ", "8"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"toyUse", " ", "=", " ", 
   RowBox[{"generatorUseData", "[", 
    RowBox[{
     RowBox[{"toyObs", "[", "\"\<Superleading\>\"", "]"}], ",", " ", 
     "toyGenerators", ",", " ", "toyVars", ",", " ", "toyKinVars"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"<|", "\n", "  ", 
  RowBox[{
   RowBox[{"\"\<Generators\>\"", " ", "->", " ", "toyGenerators"}], ",", "\n",
    "  ", 
   RowBox[{"\"\<ObstructionTerms\>\"", " ", "->", " ", 
    RowBox[{"toyObs", "[", "\"\<ObstructionTerms\>\"", "]"}]}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<F_Obs\>\"", " ", "->", " ", 
    RowBox[{"toyObs", "[", "\"\<Obstruction\>\"", "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<F_SL\>\"", " ", "->", " ", 
    RowBox[{"toyObs", "[", "\"\<Superleading\>\"", "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<PolynomialReduceQuotients\>\"", " ", "->", " ", 
    RowBox[{"toyUse", "[", "\"\<Quotients\>\"", "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<PolynomialReduceRemainder\>\"", " ", "->", " ", 
    RowBox[{"toyUse", "[", "\"\<Remainder\>\"", "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<UsedGenerators\>\"", " ", "->", " ", 
    RowBox[{"toyUse", "[", "\"\<UsedGenerators\>\"", "]"}]}]}], "\n", 
  "|>"}]}], "Input",ExpressionUUID->"e53666cf-f226-4185-9b1b-17e4fbf151a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Full", " ", "diagnostic", " ", "scan", " ", "over", " ", "generator"}], "-", 
    RowBox[{"set", " ", 
     RowBox[{"candidates", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{"obstructionGeneratorDiagnostic", "[", 
   RowBox[{
   "toyF0", ",", " ", "toyVars", ",", " ", "toyKinAssumptions", ",", " ", 
    "toyKinVars", ",", " ", "8", ",", " ", "2"}], "]"}]}]], "Input",Expression\
UUID->"755008a2-b63f-4faf-9ef8-4e0323d3964e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Project command pattern for the five-point collinear example", "Section",ExpressionUUID->"03980781-e7eb-44d7-a413-1b9d1a3fcca6"],

Cell["\<\
After running 03_FivePoint_Spacelike_Collinear.wl, the same objects are \
available for actual graph topologies. The following cells are written \
defensively: they only run if the example data already exist in the kernel.\
\>", "Text",ExpressionUUID->"81fa8b7d-0afd-43a9-b7ab-634b9f430d5e"],

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"ValueQ", "[", "UFCollinear2Loop7Prop", "]"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"case7", " ", "=", " ", 
     RowBox[{"First", "@", 
      RowBox[{"Select", "[", 
       RowBox[{"UFCollinear2Loop7Prop", ",", " ", 
        RowBox[{
         RowBox[{"AssociationQ", "[", 
          RowBox[{"Lookup", "[", 
           RowBox[{
            RowBox[{"#", " ", "[", "\"\<InteriorObstructionScan\>\"", "]"}], ",",
             " ", "\"\<ObstructionData\>\"", ",", " ", 
            RowBox[{"Missing", "[", "]"}]}], "]"}], "]"}], " ", "&"}]}], 
       "]"}]}]}], ";", "\n", "  ", 
    RowBox[{"obs7", " ", "=", " ", 
     RowBox[{"case7", "[", 
      RowBox[{"\"\<InteriorObstructionScan\>\"", ",", 
       " ", "\"\<ObstructionData\>\""}], "]"}]}], ";", "\n", "  ", 
    RowBox[{"<|", "\n", "    ", 
     RowBox[{
      RowBox[{"\"\<Topology\>\"", " ", "->", " ", 
       RowBox[{"case7", "[", "\"\<TopologyTeX\>\"", "]"}]}], ",", "\n", 
      "    ", 
      RowBox[{"\"\<CancellationFactors\>\"", " ", "->", " ", 
       RowBox[{"case7", "[", 
        RowBox[{"\"\<InteriorObstructionScan\>\"", ",", 
         " ", "\"\<CancellationFactors\>\""}], "]"}]}], ",", "\n", "    ", 
      RowBox[{"\"\<Generators\>\"", " ", "->", " ", 
       RowBox[{"case7", "[", 
        RowBox[{"\"\<InteriorObstructionScan\>\"", ",", 
         " ", "\"\<Generators\>\""}], "]"}]}], ",", "\n", "    ", 
      RowBox[{"\"\<F_Obs\>\"", " ", "->", " ", 
       RowBox[{"obs7", "[", "\"\<Obstruction\>\"", "]"}]}], ",", "\n", "    ", 
      RowBox[{"\"\<F_SL\>\"", " ", "->", " ", 
       RowBox[{"obs7", "[", "\"\<Superleading\>\"", "]"}]}], ",", "\n", 
      "    ", 
      RowBox[{"\"\<GeneratorUseData\>\"", " ", "->", " ", 
       RowBox[{"case7", "[", 
        RowBox[{"\"\<InteriorObstructionScan\>\"", ",", 
         " ", "\"\<GeneratorUseData\>\""}], "]"}]}]}], "\n", "  ", "|>"}]}], ",",
    "\n", "  ", "\"\<Run \
Get[NotebookDirectory[]<>\\\"03_FivePoint_Spacelike_Collinear.wl\\\"] first \
to use this cell.\>\""}], "\n", "]"}]], "Input",ExpressionUUID->"55730551-\
4966-4a96-b046-e9bb2c17ea16"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Layer V: Scaling geometry and uniqueness diagnostics", "Section",ExpressionUUID->"33c79965-4c10-48c2-acc5-06d97df96067"],

Cell["\<\
The scaling routine enforces three conditions: (1) all F_SL monomials have \
one common pre-cancellation weight W_SL; (2) W_SL is strictly more singular \
than the first surviving Lee--Pomeransky weight W_HR from U+F_Obs; (3) every \
active variable is covered either by an F_SL monomial at W_SL or by a \
surviving U/F_Obs monomial at W_HR. The unit gap is reported but not imposed.\
\
\>", "Text",ExpressionUUID->"f3556327-3eaa-4c55-b0ed-9c7d45b70298"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "hrfFSLLinearConstraintData", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hrfFSLLinearConstraintData", "[", 
    RowBox[{"fSL_", ",", " ", "vars_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"fSLList", ",", " ", "rows", ",", " ", "A"}], "}"}], ",", "\n", 
     "  ", 
     RowBox[{
      RowBox[{"fSLList", " ", "=", " ", 
       RowBox[{"DeleteCases", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{"{", "fSL", "}"}], "]"}], ",", " ", "0"}], "]"}]}], ";", 
      "\n", "  ", 
      RowBox[{"rows", " ", "=", " ", 
       RowBox[{"Join", " ", "@@", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"polynomialExponentRows", "[", 
            RowBox[{"#", ",", " ", "vars"}], "]"}], " ", "&"}], " ", "/@", 
          " ", "fSLList"}], ")"}]}]}], ";", "\n", "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Length", "[", "rows", "]"}], " ", "<", " ", "2"}], ",", " ", 
        RowBox[{"Return", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<ExponentRows\>\"", " ", "->", " ", "rows"}], ",", " ", 
           RowBox[{"\"\<ConstraintMatrix\>\"", " ", "->", " ", 
            RowBox[{"{", "}"}]}], ",", " ", 
           RowBox[{"\"\<Rank\>\"", " ", "->", " ", "0"}], ",", " ", 
           RowBox[{"\"\<NullSpace\>\"", " ", "->", " ", 
            RowBox[{"IdentityMatrix", "[", 
             RowBox[{"Length", "[", "vars", "]"}], "]"}]}], ",", " ", 
           
           RowBox[{"\"\<AffineDimensionIgnoringDeltaPowers\>\"", " ", "->", 
            " ", 
            RowBox[{"Length", "[", "vars", "]"}]}]}], "|>"}], "]"}]}], "]"}], 
      ";", "\n", "  ", 
      RowBox[{"A", " ", "=", " ", 
       RowBox[{
        RowBox[{"Rest", "[", "rows", "]"}], " ", "-", " ", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{
          RowBox[{"First", "[", "rows", "]"}], ",", " ", 
          RowBox[{
           RowBox[{"Length", "[", "rows", "]"}], " ", "-", " ", "1"}]}], 
         "]"}]}]}], ";", "\n", "  ", 
      RowBox[{"<|", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<ExponentRows\>\"", " ", "->", " ", "rows"}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<ConstraintMatrix\>\"", " ", "->", " ", "A"}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<Rank\>\"", " ", "->", " ", 
         RowBox[{"MatrixRank", "[", "A", "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<NullSpace\>\"", " ", "->", " ", 
         RowBox[{"NullSpace", "[", "A", "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<AffineDimensionIgnoringDeltaPowers\>\"", " ", "->", " ", 
         
         RowBox[{
          RowBox[{"Length", "[", "vars", "]"}], " ", "-", " ", 
          RowBox[{"MatrixRank", "[", "A", "]"}]}]}]}], "\n", "  ", "|>"}]}]}],
     "\n", "]"}]}], ";"}]}], "Input",ExpressionUUID->"a13ce3cb-acb2-48ac-8c49-\
8ae14afa9afc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "hrfScalingGeometryAudit", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hrfScalingGeometryAudit", "[", 
    RowBox[{"fSL_", ",", " ", "U_", ",", " ", "vars_", ",", " ", 
     RowBox[{"maxAbs_", ":", "5"}], ",", " ", 
     RowBox[{"fObs_", ":", "None"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"lin", ",", " ", "scan", ",", " ", "accepted"}], "}"}], ",", 
     "\n", "  ", 
     RowBox[{
      RowBox[{"lin", " ", "=", " ", 
       RowBox[{"hrfFSLLinearConstraintData", "[", 
        RowBox[{"fSL", ",", " ", "vars"}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"scan", " ", "=", " ", 
       RowBox[{"findCoverageLPScaling", "[", 
        RowBox[{
        "fSL", ",", " ", "U", ",", " ", "vars", ",", " ", "maxAbs", ",", " ", 
         "fObs"}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"accepted", " ", "=", " ", 
       RowBox[{"Lookup", "[", 
        RowBox[{
        "scan", ",", " ", "\"\<AcceptedCandidateDiagnostics\>\"", ",", " ", 
         RowBox[{"{", "}"}]}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"<|", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<LinearEqualityData\>\"", " ", "->", " ", "lin"}], ",", 
        "\n", "    ", 
        RowBox[{"\"\<SelectedScaling\>\"", " ", "->", " ", 
         RowBox[{"Lookup", "[", 
          RowBox[{"scan", ",", " ", "\"\<Scaling\>\"", ",", " ", 
           RowBox[{"Missing", "[", "\"\<NoScaling\>\"", "]"}]}], "]"}]}], ",",
         "\n", "    ", 
        RowBox[{"\"\<AcceptedCount\>\"", " ", "->", " ", 
         RowBox[{"Lookup", "[", 
          RowBox[{"scan", ",", " ", "\"\<AcceptedCount\>\"", ",", " ", 
           RowBox[{"Missing", "[", "\"\<NoCount\>\"", "]"}]}], "]"}]}], ",", 
        "\n", "    ", 
        RowBox[{"\"\<CandidateCount\>\"", " ", "->", " ", 
         RowBox[{"Lookup", "[", 
          RowBox[{"scan", ",", " ", "\"\<CandidateCount\>\"", ",", " ", 
           RowBox[{"Missing", "[", "\"\<NoCount\>\"", "]"}]}], "]"}]}], ",", 
        "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"\"\<AcceptedScalings\>\"", " ", "->", " ", 
           RowBox[{"Lookup", "[", 
            RowBox[{"#", ",", " ", "\"\<ScalingVector\>\""}], "]"}]}], " ", 
          "&"}], " ", "/@", " ", "accepted"}], ",", "\n", "    ", 
        RowBox[{"\"\<SelectedDiagnostics\>\"", " ", "->", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"accepted", " ", "===", " ", 
            RowBox[{"{", "}"}]}], ",", " ", 
           RowBox[{"Missing", "[", "\"\<NoAcceptedCandidate\>\"", "]"}], ",", 
           " ", 
           RowBox[{"First", "[", "accepted", "]"}]}], "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<NearMissDiagnostics\>\"", " ", "->", " ", 
         RowBox[{"Lookup", "[", 
          RowBox[{"scan", ",", " ", "\"\<NearMissDiagnostics\>\"", ",", " ", 
           RowBox[{"{", "}"}]}], "]"}]}]}], "\n", "  ", "|>"}]}]}], "\n", 
    "]"}]}], ";"}]}], "Input",ExpressionUUID->"566389b1-9763-4a64-9ee1-\
130925b61d82"],

Cell["\<\
Apply the scaling audit to the toy obstruction. For the toy example we choose \
a simple toy U only to demonstrate the diagnostic structure; physical \
conclusions should be drawn from the graph examples below.\
\>", "Text",ExpressionUUID->"0cb72970-bbbb-47dd-8fb9-00deab4150aa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"toyU", " ", "=", " ", 
   RowBox[{
   "x0", " ", "+", " ", "x1", " ", "+", " ", "x2", " ", "+", " ", "x3", " ", "+",
     " ", "x4"}]}], ";"}], "\n", 
 RowBox[{"hrfScalingGeometryAudit", "[", 
  RowBox[{
   RowBox[{"toyObs", "[", "\"\<Superleading\>\"", "]"}], ",", " ", "toyU", ",",
    " ", "toyVars", ",", " ", "3", ",", " ", 
   RowBox[{"toyObs", "[", "\"\<Obstruction\>\"", "]"}]}], "]"}]}], "Input",Exp\
ressionUUID->"3cda1334-23ef-40ea-8540-66075ac7653d"],

Cell["\<\
Apply the scaling audit to a real five-point collinear topology, if 03 has \
been loaded.\
\>", "Text",ExpressionUUID->"d2698bf6-e007-4d18-9c8f-ad3dd96956a4"],

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ValueQ", "[", "case7", "]"}], " ", "&&", " ", 
    RowBox[{"AssociationQ", "[", "case7", "]"}]}], ",", "\n", "  ", 
   RowBox[{"hrfScalingGeometryAudit", "[", 
    RowBox[{
     RowBox[{"obs7", "[", "\"\<Superleading\>\"", "]"}], ",", " ", 
     RowBox[{"case7", "[", "\"\<U\>\"", "]"}], ",", " ", 
     RowBox[{"case7", "[", "\"\<Variables\>\"", "]"}], ",", " ", "5", ",", 
     " ", 
     RowBox[{"obs7", "[", "\"\<Obstruction\>\"", "]"}]}], "]"}], ",", "\n", 
   "  ", "\"\<Load 03_FivePoint_Spacelike_Collinear.wl and run the previous \
project-data cell first.\>\""}], "\n", "]"}]], "Input",ExpressionUUID->\
"19a71e93-b885-43f5-b60a-d2dc136bde3d"],

Cell[CellGroupData[{

Cell["Compact accepted-candidate table", "Subsection",ExpressionUUID->"c94d5368-ad6e-4bb2-ab2b-18e752fcf609"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "hrfAcceptedCandidateTable", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"hrfAcceptedCandidateTable", "[", "scan_Association", "]"}], " ", 
    ":=", " ", 
    RowBox[{"Dataset", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"KeyTake", "[", 
        RowBox[{"#", ",", " ", 
         RowBox[{"{", "\n", "    ", 
          
          RowBox[{"\"\<ScalingVector\>\"", ",", " ", "\"\<FSLWeight\>\"", ",",
            " ", "\"\<PostCancellationLeadingWeight\>\"", ",", "\n", 
           "    ", "\"\<HierarchyGapPostLPminusFSL\>\"", ",", 
           " ", "\"\<UnitGapQ\>\"", ",", "\n", 
           "    ", "\"\<VariablesCoveredByFSLAtWSL\>\"", ",", 
           " ", "\"\<VariablesInPostCancellationLeadingSupport\>\"", ",", 
           "\n", "    ", \
"\"\<VariablesMissingFromLeadingRegionCoverage\>\""}], "\n", "  ", "}"}]}], 
        "]"}], " ", "&"}], " ", "/@", " ", 
      RowBox[{"Lookup", "[", 
       RowBox[{
       "scan", ",", " ", "\"\<AcceptedCandidateDiagnostics\>\"", ",", " ", 
        RowBox[{"{", "}"}]}], "]"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"ValueQ", "[", "case7", "]"}], " ", "&&", " ", 
    RowBox[{"AssociationQ", "[", "case7", "]"}]}], ",", "\n", "  ", 
   RowBox[{"hrfAcceptedCandidateTable", "[", 
    RowBox[{"findCoverageLPScaling", "[", 
     RowBox[{
      RowBox[{"obs7", "[", "\"\<Superleading\>\"", "]"}], ",", " ", 
      RowBox[{"case7", "[", "\"\<U\>\"", "]"}], ",", " ", 
      RowBox[{"case7", "[", "\"\<Variables\>\"", "]"}], ",", " ", "5", ",", 
      " ", 
      RowBox[{"obs7", "[", "\"\<Obstruction\>\"", "]"}]}], "]"}], "]"}], ",", 
   "\n", "  ", "\"\<Load 03 and select case7 first.\>\""}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"07a67ed6-65eb-4bfd-b58c-73528fa96c9b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Counting independent conditions across 7- and 8-propagator topologies\
\>", "Section",ExpressionUUID->"8d9ebd75-64a4-4ce4-86ff-a56322a877ba"],

Cell["\<\
This table is meant to prepare a possible uniqueness proof. It records the \
rank of the F_SL equal-weight system, the dimension left by those equalities \
alone, the selected scaling vector, the hierarchy gap, and whether coverage \
is complete.\
\>", "Text",ExpressionUUID->"a6001ad7-0e13-49f6-b6d5-e95fd86f2e7e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "hrfScalingRow", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hrfScalingRow", "[", "row_Association", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "data", ",", " ", "cand", ",", " ", "fsl", ",", " ", "vars", ",", " ", 
       "lin"}], "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"data", " ", "=", " ", 
       RowBox[{"Lookup", "[", 
        RowBox[{"row", ",", " ", "\"\<CoverageLPScalingData\>\"", ",", " ", 
         RowBox[{"Missing", "[", "]"}]}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"!", 
          RowBox[{"AssociationQ", "[", "data", "]"}]}], " ", "||", " ", 
         RowBox[{
          RowBox[{"Lookup", "[", 
           RowBox[{
           "data", ",", " ", "\"\<AcceptedCandidateDiagnostics\>\"", ",", " ", 
            RowBox[{"{", "}"}]}], "]"}], " ", "===", " ", 
          RowBox[{"{", "}"}]}]}], ",", "\n", "    ", 
        RowBox[{"Return", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<GraphIndex\>\"", " ", "->", " ", 
            RowBox[{"Lookup", "[", 
             RowBox[{"row", ",", " ", "\"\<GraphIndex\>\"", ",", " ", 
              RowBox[{"Missing", "[", "]"}]}], "]"}]}], ",", " ", 
           RowBox[{"\"\<Topology\>\"", " ", "->", " ", 
            RowBox[{"Lookup", "[", 
             RowBox[{"row", ",", " ", "\"\<TopologyTeX\>\"", ",", " ", 
              RowBox[{"Missing", "[", "]"}]}], "]"}]}], ",", " ", 
           RowBox[{"\"\<Scaling\>\"", " ", "->", " ", 
            RowBox[{"Missing", "[", "\"\<NoAcceptedScaling\>\"", "]"}]}]}], 
          "|>"}], "]"}]}], "\n", "  ", "]"}], ";", "\n", "  ", 
      RowBox[{"cand", " ", "=", " ", 
       RowBox[{"First", "[", 
        RowBox[{"data", "[", "\"\<AcceptedCandidateDiagnostics\>\"", "]"}], 
        "]"}]}], ";", "\n", "  ", 
      RowBox[{"fsl", " ", "=", " ", 
       RowBox[{"Lookup", "[", 
        RowBox[{"row", ",", " ", "\"\<FSL\>\"", ",", " ", 
         RowBox[{"Missing", "[", "]"}]}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"vars", " ", "=", " ", 
       RowBox[{"Lookup", "[", 
        RowBox[{"row", ",", " ", "\"\<RemainingVars\>\"", ",", " ", 
         RowBox[{"Lookup", "[", 
          RowBox[{"row", ",", " ", "\"\<Variables\>\"", ",", " ", 
           RowBox[{"{", "}"}]}], "]"}]}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"lin", " ", "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"fsl", " ", "===", " ", 
           RowBox[{"Missing", "[", "]"}]}], " ", "||", " ", 
          RowBox[{"vars", " ", "===", " ", 
           RowBox[{"{", "}"}]}]}], ",", " ", 
         RowBox[{"Missing", "[", "]"}], ",", " ", 
         RowBox[{"hrfFSLLinearConstraintData", "[", 
          RowBox[{"fsl", ",", " ", "vars"}], "]"}]}], "]"}]}], ";", "\n", 
      "  ", 
      RowBox[{"<|", "\n", "    ", 
       RowBox[{
        RowBox[{"\"\<GraphIndex\>\"", " ", "->", " ", 
         RowBox[{"row", "[", "\"\<GraphIndex\>\"", "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<Topology\>\"", " ", "->", " ", 
         RowBox[{"Lookup", "[", 
          RowBox[{"row", ",", " ", "\"\<TopologyTeX\>\"", ",", " ", 
           RowBox[{"Lookup", "[", 
            RowBox[{
            "row", ",", " ", "\"\<TopologyName\>\"", ",", " ", "\"\<\>\""}], 
            "]"}]}], "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<ZeroVars\>\"", " ", "->", " ", 
         RowBox[{"Lookup", "[", 
          RowBox[{"row", ",", " ", "\"\<ZeroVars\>\"", ",", " ", 
           RowBox[{"{", "}"}]}], "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<ActiveVars\>\"", " ", "->", " ", "vars"}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<Scaling\>\"", " ", "->", " ", 
         RowBox[{"cand", "[", "\"\<ScalingVector\>\"", "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{"\"\<RankEqualities\>\"", " ", "->", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"AssociationQ", "[", "lin", "]"}], ",", " ", 
           RowBox[{"lin", "[", "\"\<Rank\>\"", "]"}], ",", " ", 
           RowBox[{"Missing", "[", "]"}]}], "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<DimAfterEqualities\>\"", " ", "->", " ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"AssociationQ", "[", "lin", "]"}], ",", " ", 
           RowBox[{
           "lin", "[", "\"\<AffineDimensionIgnoringDeltaPowers\>\"", "]"}], ",",
            " ", 
           RowBox[{"Missing", "[", "]"}]}], "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<Gap\>\"", " ", "->", " ", 
         RowBox[{"cand", "[", "\"\<HierarchyGapPostLPminusFSL\>\"", "]"}]}], ",",
         "\n", "    ", 
        RowBox[{"\"\<UnitGapQ\>\"", " ", "->", " ", 
         RowBox[{"cand", "[", "\"\<UnitGapQ\>\"", "]"}]}], ",", "\n", "    ", 
        
        RowBox[{"\"\<CoveredByFSLAtWSL\>\"", " ", "->", " ", 
         RowBox[{"cand", "[", "\"\<VariablesCoveredByFSLAtWSL\>\"", "]"}]}], ",",
         "\n", "    ", 
        RowBox[{"\"\<CoveredAtWHR\>\"", " ", "->", " ", 
         RowBox[{
         "cand", "[", "\"\<VariablesInPostCancellationLeadingSupport\>\"", 
          "]"}]}], ",", "\n", "    ", 
        RowBox[{"\"\<Missing\>\"", " ", "->", " ", 
         RowBox[{
         "cand", "[", "\"\<VariablesMissingFromLeadingRegionCoverage\>\"", 
          "]"}]}]}], "\n", "  ", "|>"}]}]}], "\n", "]"}]}], ";"}]}], "Input",E\
xpressionUUID->"f4c95a6d-481c-41f7-9a6f-444d0c3b5b5c"],

