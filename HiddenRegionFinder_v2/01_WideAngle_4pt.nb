 RowBox[{"hrfHyperCrownInteriorNarrative", "[", "]"}]], "Input",
 CellLabel->"In[21]:=",ExpressionUUID->"ab518280-3ca8-4202-bb31-605600d04e25"],

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"hrfEx04CasePopulatedQ", "[", "Ex04HyperCrownX11Target", "]"}], 
   ",", 
   RowBox[{
    RowBox[{
    "Ex04HyperCrownX11Target", "[", "\"\<GeneratorTrialTable\>\"", "]"}], 
    "[", "\"\<Polynomial\>\"", "]"}], ",", 
   "\"\<Run hrfEx04HyperCrownX11Display[] first.\>\""}], "]"}]], "Input",
