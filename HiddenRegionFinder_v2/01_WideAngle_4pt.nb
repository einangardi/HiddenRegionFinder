Notebook[{

Cell[CellGroupData[{
Cell["Wide-angle 4-point examples", "Title",ExpressionUUID->"f2ba8cf5-0d37-4c1b-a3a6-589d81750ead"],

Cell["\<\
Example 01: In[1] Crown only (~1\[AHat]\.80\.932 min). Optional HyperCrown at \
In[17]/In[19]. One kernel (Local).\
\>", "Text",ExpressionUUID->"0f7150b6-f178-491b-a6bd-c72bbfb42668"],

Cell["\<\
Kernel \"Local\" (Evaluation > Notebook's Kernel). On open, init prints a \
reminder only. Restart Kernel once manually, then run In[1] onward. Do not \
put RestartKernel in auto-run init cells.\
\>", "Text",ExpressionUUID->"071bbf1b-7cd4-4241-a8b7-83b42e2dab6f"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Print", "[", 
   "\"\<HRF notebook loaded. Before In[1], use Evaluation > Restart Kernel \
once (manual).\>\"", "]"}], ";"}]], "Input",
 InitializationCell->True,
 ShowCellTags->False,
 CellLabel->"init:=",ExpressionUUID->"b7fedb10-4476-413c-ab51-3aa955e501a5"],

Cell["Setup", "Section",ExpressionUUID->"44f6d252-9d45-4ee3-8850-f10e85c01833"],

Cell["\<\
Example 01 (light load). In[1] loads diagrams + polynomial patch + Crown \
interior only (~1\[AHat]\.80\.932 min, WideAngle4pt preset). HyperCrown \
{x11}=0 is optional at In[17]. HyperCrown full interior is optional at \
In[19]. Run one notebook at a time on Local kernel.\
\>", "Text",ExpressionUUID->"b67925e3-4582-44c9-b8aa-d67ba6555716"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$HRFQuietReports", "=", "True"}], ";", 
  RowBox[{"$HRFExample01Report", "=", "True"}], ";", 
  RowBox[{"$HRFExample04Report", "=", "True"}], ";", 
  RowBox[{"$HRFScalingReport", "=", "False"}], ";", 
  RowBox[{"$HRFRunCrownInteriorScanOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFRunHyperCrownBoundaryScansOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFRunSuperCrownBoundaryScanOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFRunDivingBeetleDiagnosticsOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFRunHyperCrownInteriorScan", "=", "False"}], ";", 
  RowBox[{"$HRFRunDivingBeetleInteriorScanOnLoad", "=", "False"}], ";", 
  RowBox[{"$HRFEx04CompareBinomialQ", "=", "False"}], ";", 
  RowBox[{"$HRFEx04TrimScanStorageQ", "=", "True"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<HiddenRegionFinder.wl\>\""}], "}"}], "]"}], "]"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<01_WideAngle_2to2_OffShell.wl\>\""}], "}"}], "]"}], "]"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<HRF_PolynomialCancellationFactors.wl\>\""}], "}"}], "]"}], "]"}], 
  ";", 
  RowBox[{"$HRFPolynomialMaxMonomials", "=", "12"}], ";", 
  RowBox[{"$HRFPolynomialRequireKinematicDomainQ", "=", "False"}], ";", 
  RowBox[{"hrfInstallPolynomialCancellationPatch", "[", "]"}], ";", 
  RowBox[{"$HRFEx04RunObstructionSearchQ", "=", "True"}], ";", 
  RowBox[{"$HRFFindObstructionsStopOnFirstAdmissibleQ", "=", "False"}], ";", 
  RowBox[{"$HRFCandidateGeneratorSetLimit", "=", "64"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<04_PolynomialFactor_Regression.wl\>\""}], "}"}], "]"}], "]"}], ";", 
  RowBox[{"Ex04CrownRegression", "=", 
   RowBox[{"hrfEx04CrownRegression", "[", "]"}]}], ";", 
  RowBox[{
  "Print", "[", "\"\<=== Example 01 CORE LOAD COMPLETE ===\>\"", "]"}], ";", 
  RowBox[{
  "Print", "[", 
   "\"\<Polynomial-only (no binomial). Next: In[2] Crown table; optional \
HyperCrown cells below.\>\"", "]"}], ";"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"c405b256-f6e8-46f5-89b2-f3c5bb15a768"],

Cell["Crown sanity check", "Section",ExpressionUUID->"6d096907-cb8f-4cd6-95c1-57539dd3c079"],

Cell["\<\
Wide-angle Crown interior (polynomial). Requires setup In[1] complete. Shows \
generators and scaling vector.\
\>", "Text",ExpressionUUID->"72888e7c-6646-457b-99ae-4456cd1faf05"],

Cell[BoxData[
 RowBox[{"hrfEx04CrownSanityDisplay", "[", "]"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"2fec5978-52e4-4290-a768-62fadb811641"],

Cell["Diagrams", "Section",ExpressionUUID->"4d1ac213-e701-4bdd-8397-4af7854ce47c"],

Cell[BoxData[
 RowBox[{"drawGraphFromPySecDecInput", "[", 
  RowBox[{"CrownInternalEdges", ",", "CrownExternalEdges"}], "]"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"9e4dc094-a931-4540-860d-39362dfbaf6c"],

Cell[BoxData[
 RowBox[{"drawGraphFromPySecDecInput", "[", 
