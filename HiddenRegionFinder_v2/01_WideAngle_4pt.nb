Cell[BoxData[
 RowBox[{"drawGraphFromPySecDecInput", "[", 
  RowBox[{"DBInternalEdges", ",", "CrownExternalEdges"}], "]"}]], "Input",
 CellLabel->"In[6]:=",ExpressionUUID->"2dfe701b-828e-47bd-87f6-00f6dafebd1a"],

Cell["Crown interior (reference hidden region)", "Section",ExpressionUUID->"51c505b6-936d-408d-806c-2aeb1c2d9d36"],

Cell["\<\
Optional binomial Crown reference (slow if polynomial patch already active). \
Set $HRFRunCrownInteriorScanOnLoad=True and reload 01 before the patch, or \
evaluate manually.\
\>", "Text",ExpressionUUID->"ae2a08b0-1400-4ac1-a4d6-521c3ba0c5ff"],

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"AssociationQ", "[", "CrownScan", "]"}], ",", 
   RowBox[{"Dataset", "[", 
    RowBox[{"{", 
     RowBox[{"KeyTake", "[", 
      RowBox[{
       RowBox[{"hrfHiddenSummaryRow", "[", 
        RowBox[{"\"\<Crown\>\"", ",", "\"\<Interior\>\"", ",", 
         RowBox[{"{", "}"}], ",", "VarsCrown", ",", "CrownScan", ",", 
         RowBox[{"hrfCoverageData", "[", 
          RowBox[{"CrownScan", ",", 
           RowBox[{
            RowBox[{"CrownData", "[", "\"\<UF\>\"", "]"}], "[", "\"\<U\>\"", 
            "]"}], ",", "VarsCrown", ",", "5"}], "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<Region vector\>\"", ",", "\"\<Hidden region identified?\>\"", 
         ",", "\"\<Scaling vector\>\"", ",", 
         "\"\<Variable scaling by region variable\>\"", ",", 
         "\"\<Comment\>\""}], "}"}]}], "]"}], "}"}], "]"}], ",", 
   "\"\<CrownScan not run (binomial interior disabled)\>\""}], "]"}]], "Input",\

 CellLabel->"In[7]:=",ExpressionUUID->"e0672d92-7d64-4474-af41-52144532c97e"],

Cell["Interior region-study tables", "Section",ExpressionUUID->"db676dac-25bc-4178-8567-03a0266775f4"],

Cell["\<\
After In[1] these tables are empty for HyperCrown until optional Ex04 runs: \
In[17] ({x11}=0 boundary) and/or In[19] (full interior), then re-evaluate \
In[8] and In[13]. Diving Beetle polynomial runs live in \
01a_DivingBeetle_WideAngle.nb (interior + {x8,x9} boundary); In[9] here is \
legacy PairSectors only if you set load flags before In[1].\
\>", "Text",ExpressionUUID->"4c37dbe6-24d6-4f98-a94d-349c26ab9f96"],

Cell[BoxData[
 RowBox[{"hrfHyperCrownRegionStudyTable", "[", "]"}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"b0200d6b-be59-4d36-abed-ccc13337c58a"],

Cell[BoxData[
 RowBox[{"hrfDivingBeetleRegionStudyTable", "[", "]"}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"e198741d-63a4-4fe4-a637-186f0b0f838d"],

Cell["Boundary outcome tables", "Section",ExpressionUUID->"841bb0ad-2a94-4c25-8dd0-ff69b440ca5f"],

Cell["\<\
HyperCrown boundary table requires $HRFRunHyperCrownBoundaryScansOnLoad=True \
before setup (15 strata, slow).\
\>", "Text",ExpressionUUID->"d3b46032-ecb9-44a1-9d79-270a72838d51"],

Cell[BoxData[
 RowBox[{"hrfEx01BoundaryOutcomeTable", "[", 
  "HyperCrownBoundaryCandidateScans", "]"}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"3de0967b-add5-4226-bcbe-8f93b03cfb06"],

Cell[BoxData[
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"ValueQ", "[", "DBBoundaryOutcomeTable", "]"}], ",", 
   "DBBoundaryOutcomeTable", ",", 
   "\"\<Diving Beetle boundary scan not run\>\""}], "]"}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"b7c0af1d-644e-4a0d-84d8-1fc606b987db"],

Cell[BoxData[
 RowBox[{"hrfDivingBeetleFailureNarrative", "[", "]"}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"81fb9501-2932-409f-a9e5-fd1f52d0785b"],

Cell["Channel obstruction attempts (HyperCrown)", "Section",ExpressionUUID->"4fd16fe9-7d1d-47eb-8e17-1f4939e49a46"],

Cell["\<\
Populates after In[17]/In[19] (same Ex04 bridge as In[8]); re-run this cell \
after those optional runs.\
\>", "Text",ExpressionUUID->"97a4a0ba-c8ea-4db9-bcee-f6348088e6c4"],

Cell[BoxData[
 RowBox[{"hrfHyperCrownChannelAttemptTable", "[", "]"}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"ba663537-3b9c-4959-980e-8f3776439c9f"],

Cell["Polynomial hidden regions (Crown + HyperCrown)", "Section",ExpressionUUID->"3ff7b58b-7bc2-4af3-a072-beb2dffcd7a5"],

Cell["\<\
In[1] computed Ex04CrownRegression only. Optional HyperCrown {x11}=0 (~30 s) \
at In[17]. Full HyperCrown interior (~10\[AHat]\.80\.9320 min, \
polynomial-only) at In[19] only if needed.\
\>", "Text",ExpressionUUID->"e2bcd860-82fd-4e04-b58a-7e417bf7681b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$HRFEx04RunObstructionSearchQ", "=", "True"}], ";", 
  RowBox[{"$HRFFindObstructionsStopOnFirstAdmissibleQ", "=", "False"}], ";", 
  RowBox[{"$HRFCandidateGeneratorSetLimit", "=", "64"}], ";", 
  RowBox[{"$HRFObstructionFindInstanceTimeLimit", "=", "20"}], ";", 
  RowBox[{"$HRFPolynomialRequireKinematicDomainQ", "=", "False"}], ";", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", 
     RowBox[{"ValueQ", "[", "Ex04CrownRegression", "]"}]}], ",", 
    RowBox[{"Get", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"NotebookDirectory", "[", "]"}], ",", 
        "\"\<04_PolynomialFactor_Regression.wl\>\""}], "}"}], "]"}], "]"}]}], 
   "]"}], ";"}]], "Input",
 CellLabel->"In[14]:=",ExpressionUUID->"e88819a2-4890-4c27-87b3-5e06cdb50fd8"],

Cell["\<\
Crown interior (polynomial, PairSectors) \[AHat]\.80\.94 from In[1] unless \
missing.\
\>", "Text",ExpressionUUID->"4fdab901-2d52-4fba-9081-dbf5c7e18266"],

Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"!", 
