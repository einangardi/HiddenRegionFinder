Cell[CellGroupData[{
Cell["Spacelike collinear 5-point examples", "Title",ExpressionUUID->"364e1779-02c0-4717-9595-2a34bf5e474f"],

Cell["\<\
Seed diagnostic at In[1]-In[5]. Full 7/8-propagator scan at In[6] (optional). \
Polynomial study at In[14].\
\>", "Text",ExpressionUUID->"9614b01b-ac01-49a4-b761-590379484900"],

Cell["\<\
Kernel \"Local\" (Evaluation > Notebook's Kernel). On open, init prints a \
reminder only. Restart Kernel once manually, then run In[1] onward. Do not \
put RestartKernel in auto-run init cells.\
\>", "Text",ExpressionUUID->"45e6efc2-d192-4625-ab63-026dea719c15"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Print", "[", 
   "\"\<HRF notebook loaded. Before In[1], use Evaluation > Restart Kernel \
once (manual).\>\"", "]"}], ";"}]], "Input",
 InitializationCell->True,
 ShowCellTags->False,
 CellLabel->"init:=",ExpressionUUID->"85ba98eb-8454-421b-aef5-1b105f9ab853"],

Cell["\<\
Run the seed diagram diagnostic (In[1]-In[5]) first. The full 7/8-propagator \
topology scan is disabled until the seed case finds a hidden region with a \
single generator.\
\>", "Text",ExpressionUUID->"1e6bbc32-302b-46a5-b2c2-3560f2ac1ed4"],

Cell[CellGroupData[{

Cell["Seed diagram diagnostic (run first)", "Section",ExpressionUUID->"d2df38e2-3f1b-4449-8687-099e5d8c59aa"],

Cell["\<\
Fast seed-only workflow (matches working binomial Ex03): polynomial f_k \
kin-normalized and Mandelstam-linear, SingleProduct generator g = product of \
all simultaneously admissible f_k. In[4] should show \
SafeSingleProductSetCount >= 1 before In[5].\
\>", "Text",ExpressionUUID->"e06bc8fc-8765-45c7-a000-8143951f0350"],

