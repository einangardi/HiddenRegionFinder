      RowBox[{"\<\"HiddenRegionWithValidScalingCount\"\>", "\[Rule]", "1"}], ",", 
      RowBox[{"\<\"ScalingEvaluatedOnValidTrialsQ\"\>", "\[Rule]", "True"}], ",", 
      RowBox[{"\<\"GeneratorCountHistogram\"\>", "\[Rule]", 
       RowBox[{"\[LeftAssociation]", 
        RowBox[{"1", "\[Rule]", "1"}], "\[RightAssociation]"}]}], ",", 
      RowBox[{"\<\"StopOnFirstValidObstructionQ\"\>", "\[Rule]", "False"}], ",", 
      RowBox[{"\<\"StoppedEarlyOnValidObstructionQ\"\>", "\[Rule]", 
       "False"}]}], "\[RightAssociation]"}]}]}], 
