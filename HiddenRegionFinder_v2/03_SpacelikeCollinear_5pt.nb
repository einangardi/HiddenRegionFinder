Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"HiddenRegionQ\"\>", "\[Rule]", "True"}], ",", 
   RowBox[{"\<\"Generators\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x1", " ", "x4"}], "+", 
        RowBox[{"x", " ", "x0", " ", "x5"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "x2"}], "-", "x3", "+", 
        RowBox[{"x2", " ", "z"}]}], ")"}]}], "}"}]}], ",", 
