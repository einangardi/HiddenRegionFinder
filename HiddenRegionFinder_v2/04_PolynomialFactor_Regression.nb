"89fd757e-7465-4a2d-b808-9ec562766225"],

Cell["HyperCrown {x11}=0 \[LongDash] inspect generators and region", "Section",ExpressionUUID->"1e15b11e-e74e-407a-a142-346862a16517"],

Cell[BoxData[
 RowBox[{"hrfEx04InspectPolynomialScan", "[", 
  RowBox[{
  "Ex04HyperCrownX11Target", ",", "Automatic", ",", "Automatic", ",", 
   "KinAssump4ptOnShell", ",", "KinVars4pt", ",", 
   RowBox[{"Expand", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"HyperCrownData", "[", "\"\<UF\>\"", "]"}], "[", "\"\<U\>\"", 
      "]"}], "/.", "\[VeryThinSpace]", 
     RowBox[{"x11", "\[Rule]", "0"}]}], "]"}]}], "]"}]], "Input",ExpressionUUI\
D->"7a2d696b-a57d-4f52-a24d-11fc5a3c3247"],

