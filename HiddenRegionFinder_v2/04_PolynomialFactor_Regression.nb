"2b4ab4d2-1a78-4a6e-bcd7-70166360c60b"],

Cell["Optional: full 64-trial scan (HyperCrown {x11}=0, ~15 min)", "Section",ExpressionUUID->"cf592dce-cd3e-440f-bc40-73c76bbef8ea"],

Cell[BoxData["$Failed"], "Input",ExpressionUUID->"159923ea-6330-4885-b480-4d0da3290d01"],

