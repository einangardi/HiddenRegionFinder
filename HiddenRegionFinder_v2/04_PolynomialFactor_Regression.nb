Notebook[{

Cell[CellGroupData[{
Cell["Polynomial factor regression", "Title",ExpressionUUID->"39098d14-e551-413c-be36-5c817f02d2f3"],

Cell["\<\
Polynomial factor regression. Obstruction search ON by default in In[1].\
\>", "Text",ExpressionUUID->"926dcd1b-a9eb-4bb4-9551-20811a8a4acd"],

Cell["\<\
Kernel \"Local\" (Evaluation > Notebook's Kernel). On open, init prints a \
reminder only. Restart Kernel once manually, then run In[1] onward. Do not \
put RestartKernel in auto-run init cells.\
\>", "Text",ExpressionUUID->"88136b28-09cb-4545-af7c-6ffd38bc073e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
  "Print", "[", 
   "\"\<HRF notebook loaded. Before In[1], use Evaluation > Restart Kernel \
once (manual).\>\"", "]"}], ";"}]], "Input",
 InitializationCell->True,
 ShowCellTags->False,ExpressionUUID->"c9a11e91-7501-4486-9b68-fce83c047846"],

Cell["Setup", "Section",ExpressionUUID->"7ee59e2e-287d-4056-b454-a1677a1d6c0a"],

Cell["\<\
Obstruction search ON. StopOnFirstAdmissible keeps total runtime ~hour-scale. \
HyperCrown {x11}=0 ~20 s; full 64 trials ~15 min. ThreeLoopVertex candidate \
build ~15-30 min then trials. Use a fresh kernel.\
\>", "Text",ExpressionUUID->"5578a6a6-5f1d-41f9-b278-72d3b58fe24f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$HRFRunEx04RegressionOnLoad", "=", "True"}], ";", 
  RowBox[{"$HRFRunEx04SlowCasesOnLoad", "=", "True"}], ";", 
  RowBox[{"$HRFRunEx04FivePointOnLoad", "=", "True"}], ";", 
  RowBox[{"$HRFExample04Report", "=", "True"}], ";", 
  RowBox[{"$HRFScalingReport", "=", "False"}], ";", 
  RowBox[{"$HRFCandidateGeneratorSetLimit", "=", "64"}], ";", 
  RowBox[{"$HRFEx04RunObstructionSearchQ", "=", "True"}], ";", 
  RowBox[{"$HRFFindObstructionsStopOnFirstAdmissibleQ", "=", "False"}], ";", 
  RowBox[{"$HRFMaxProductSubsetSize", "=", "2"}], ";", 
  RowBox[{"$HRFObstructionFindInstanceTimeLimit", "=", "20"}], ";", 
  RowBox[{"$HRFPolynomialRequireKinematicDomainQ", "=", "False"}], ";", 
  RowBox[{"$HRFEx04GeneratorPairTableMaxFactors", "=", "16"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<HiddenRegionFinder.wl\>\""}], "}"}], "]"}], "]"}], ";", 
  RowBox[{"Get", "[", 
   RowBox[{"FileNameJoin", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"NotebookDirectory", "[", "]"}], ",", 
      "\"\<04_PolynomialFactor_Regression.wl\>\""}], "}"}], "]"}], "]"}], 
  ";"}]], "Input",ExpressionUUID->"d6cba25c-c78d-4092-acc2-fa1bcf33ac77"],

Cell["Regression comparison", "Section",ExpressionUUID->"3eab68e7-0345-4f65-a2ea-c70051db2233"],

Cell[BoxData[
 RowBox[{"InterpretationBox", "[", 
  RowBox[{
   RowBox[{"StyleBox", "[", 
    RowBox[{"\"\<Ex04PolynomialRegressionTable\>\"", ",", 
     RowBox[{"ShowStringCharacters", "\[Rule]", "True"}]}], "]"}], ",", 
   "Ex04PolynomialRegressionTable", ",", 
   RowBox[{"Editable", "\[Rule]", "False"}]}], "]"}]], "Input",ExpressionUUID->\
"f51ed72a-927a-4ed2-aad5-cb22863d0900"],

