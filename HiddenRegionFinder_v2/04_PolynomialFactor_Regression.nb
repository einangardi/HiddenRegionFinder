a096-82c5a47f8d68"],

Cell[BoxData[
 RowBox[{"hrfEx04GeneratorPairTable", "[", 
  RowBox[{"Ex04HyperCrownX11Target", ",", "\"\<Polynomial\>\"", ",", 
