Notebook[{
Cell["One-row topology tables for the paper", "Title"],
Cell["This notebook builds compact paper-oriented tables with one row per opened topology.  Each row records the interior hidden-region scaling vector and the corresponding boundary hidden-region data.  The columns `...WHRVars` list the variables appearing in monomials of the post-cancellation leading Lee--Pomeransky support at weight W_HR.", "Text"],
Cell[BoxData["$HRFScalingReport = False;\nGet[NotebookDirectory[]<>\"HiddenRegionFinder.wl\"];\nGet[NotebookDirectory[]<>\"03_FivePoint_Spacelike_Collinear.wl\"];"], "Input"],
Cell["Helper functions", "Section"],
Cell[BoxData["ClearAll[missingDash, compactList, regionValue, sortedBoundaryRows, nthRow, oneRowTopologyTable];\n\nmissingDash[x_] := If[MatchQ[x, _Missing] || x === {} || x === Null, \"--\", x];\n\n(* Force vectors/lists to appear as compact one-line Mathematica lists in Dataset/CSV. *)\ncompactList[x_] := Which[\n  MatchQ[x, _Missing] || x === {} || x === Null, \"--\",\n  AssociationQ[x], ToString[InputForm[Values[x]]],\n  ListQ[x], ToString[InputForm[x]],\n  True, x\n];\n\nregionValue[row_, key_] := Module[{val},\n  If[! AssociationQ[row], Return[\"--\"]];\n  val = Lookup[row, key, Missing[\"Absent\"]];\n  If[StringContainsQ[key, \"Scaling\"] || StringContainsQ[key, \"Vars\"], compactList[val], missingDash[val]]\n];\n\nsortedBoundaryRows[rows_] := SortBy[rows, ToString[Lookup[#, \"ZeroVars\", {}]] &];\n\nnthRow[rows_, n_Integer] := If[Length[rows] >= n, rows[[n]], Missing[\"Absent\"]];\n\noneRowTopologyTable[topologySummary_, regionRows_, boundarySlots_Integer] := Module[\n  {hiddenRows, topologies},\n  hiddenRows = Select[regionRows, TrueQ[Lookup[#, \"HiddenRegionQ\", False]] &];\n  topologies = topologySummary[[All, {\"GraphIndex\", \"TopologyName\", \"TopologyTeX\"}]];\n  Table[\n    Module[{top = topo[\"Topology\"], interior, boundaries, base, bcols},\n      interior = FirstCase[hiddenRows, r_ /; Lookup[r, \"Topology\", None] === top && Lookup[r, \"RegionType\", None] === \"Interior\", Missing[\"Absent\"]];\n      boundaries = sortedBoundaryRows @ Select[hiddenRows, Lookup[#, \"Topology\", None] === top && Lookup[#, \"RegionType\", None] === \"Boundary\" &];\n      base = <|\n        \"Topology\" -> topo[\"TopologyTeX\"],\n        \"GraphIndex\" -> topo[\"GraphIndex\"],\n        \"InteriorScaling\" -> regionValue[interior, \"ScalingVector\"],\n        \"InteriorWHRVars\" -> regionValue[interior, \"CoveredAtWHR\"]\n      |>;\n      bcols = Association @ Flatten @ Table[\n        With[{b = nthRow[boundaries, j]},\n          {\n            \"Boundary\"<>ToString[j]<>\"ZeroVars\" -> regionValue[b, \"ZeroVars\"],\n            \"Boundary\"<>ToString[j]<>\"Scaling\" -> regionValue[b, \"ScalingVector\"],\n            \"Boundary\"<>ToString[j]<>\"WHRVars\" -> regionValue[b, \"CoveredAtWHR\"]\n          }\n        ],\n        {j, boundarySlots}\n      ];\n      Join[base, bcols]\n    ],\n    {topo, topologies /. a_Association :> <|\"GraphIndex\" -> a[\"GraphIndex\"], \"Topology\" -> a[\"TopologyName\"], \"TopologyTeX\" -> a[\"TopologyTeX\"]|>}\n  ]\n];"], "Input"],
Cell["Seven-propagator table: one boundary slot", "Section"],
Cell[BoxData["PaperOneRowTable2Loop7Prop = oneRowTopologyTable[TopologySummary2Loop7Prop, TopologyRegionScalingSummary2Loop7Prop, 1];\nPaperOneRowTable2Loop7Prop // Dataset"], "Input"],
Cell["Eight-propagator table: two boundary slots", "Section"],
Cell[BoxData["PaperOneRowTable2Loop8Prop = oneRowTopologyTable[TopologySummary2Loop8Prop, TopologyRegionScalingSummary2Loop8Prop, 2];\nPaperOneRowTable2Loop8Prop // Dataset"], "Input"],
Cell["Optional exports", "Section"],
Cell[BoxData["Export[NotebookDirectory[]<>\"PaperOneRowTable2Loop7Prop.csv\", Normal[PaperOneRowTable2Loop7Prop]];\nExport[NotebookDirectory[]<>\"PaperOneRowTable2Loop8Prop.csv\", Normal[PaperOneRowTable2Loop8Prop]];"], "Input"]
}]
