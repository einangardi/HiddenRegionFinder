Cell[BoxData[
 RowBox[{"hrfEx02ChannelLegend", "[", "]"}]], "Input",ExpressionUUID->"7a7467e8-4fdd-4cce-95ba-80e4622182e4"],

Cell[BoxData[
 TagBox[
  TagBox[
   DynamicModuleBox[{TypeSystem`NestedGrid`PackagePrivate`$state$$ = <|
    "InitialData" -> {<|
       "Regge channel" -> "T23", "Description" -> 
        "Regge channel T23 | t = s23, s = s12 | \[Delta] = -s23/s12 > 0 | \
leading limit: s23 -> 0 with s12 kept", "Kin vars" -> "{s12}", "Assumptions" -> 
        "s12 > 0"|>, <|
       "Regge channel" -> "T12", "Description" -> 
        "Regge channel T12 | t = s12, s = s23 | \[Delta] = -s12/s23 > 0 | \
leading limit: s12 -> 0 with s23 kept", "Kin vars" -> "{s23}", "Assumptions" -> 
        "s23 < 0"|>, <|
       "Regge channel" -> "T13", "Description" -> 
        "Regge channel T13 | t = s13, s = s12 | \[Delta] = -s13/s12 > 0 | \
leading limit: s13 -> 0 with s12 kept", "Kin vars" -> "{s12}", "Assumptions" -> 
        "s12 > 0"|>}, "AllowEmbedding" -> True, "InitialShape" -> 
     TypeSystem`PackageScope`HeaderShape[<|{All, "Regge channel"} -> 
        1, {All, "Description"} -> 1, {All, "Kin vars"} -> 
        1, {All, "Assumptions"} -> 1|>, 
       TypeSystem`PackageScope`Limited[
        TypeSystem`PackageScope`ColumnShape[
         TypeSystem`PackageScope`Limited[
          
          TypeSystem`PackageScope`RowShape[<|
           "Regge channel" -> TypeSystem`PackageScope`AtomShape[33.6], 
            "Description" -> TypeSystem`PackageScope`AtomShape[560.], 
            "Kin vars" -> 
            TypeSystem`PackageScope`AtomShape[56.00000000000001], 
            "Assumptions" -> TypeSystem`PackageScope`AtomShape[78.4]|>], 
          DirectedInfinity[1], 4, {All}]], 3, 
        DirectedInfinity[1], {}]], "InitialType" -> TypeSystem`Vector[
       TypeSystem`Struct[{
        "Regge channel", "Description", "Kin vars", "Assumptions"}, {
         TypeSystem`Atom[String], 
         TypeSystem`Atom[String], 
         TypeSystem`Atom[String], 
         TypeSystem`Atom[String]}], 3], "Meta" -> <||>, "RowTarget" -> 20, 
     "ColumnTarget" -> 10, "Shape" -> 
     TypeSystem`PackageScope`HeaderShape[<|{All, "Regge channel"} -> 
        1, {All, "Description"} -> 1, {All, "Kin vars"} -> 
        1, {All, "Assumptions"} -> 1|>, 
       TypeSystem`PackageScope`Limited[
        TypeSystem`PackageScope`ColumnShape[
         TypeSystem`PackageScope`Limited[
          
          TypeSystem`PackageScope`RowShape[<|
           "Regge channel" -> TypeSystem`PackageScope`AtomShape[33.6], 
            "Description" -> TypeSystem`PackageScope`AtomShape[560.], 
            "Kin vars" -> 
            TypeSystem`PackageScope`AtomShape[56.00000000000001], 
            "Assumptions" -> TypeSystem`PackageScope`AtomShape[78.4]|>], 
          DirectedInfinity[1], 4, {All}]], 3, 
        DirectedInfinity[1], {}]], "Type" -> TypeSystem`Vector[
       TypeSystem`Struct[{
        "Regge channel", "Description", "Kin vars", "Assumptions"}, {
         TypeSystem`Atom[String], 
         TypeSystem`Atom[String], 
         TypeSystem`Atom[String], 
         TypeSystem`Atom[String]}], 3], "Path" -> {}, "DisplayedRowCount" -> 
     3, "DisplayedColumnCount" -> 4, "DataRowCount" -> 3, "DataColumnCount" -> 
     4, "SortPaths" -> {}, "SortDirections" -> {}, "HiddenItemsMap" -> Null, 
     "UpdateType" -> 1|>, TypeSystem`NestedGrid`PackagePrivate`$outputID$$, 
    TypeSystem`NestedGrid`PackagePrivate`$path$$ = {}, 
    TypeSystem`NestedGrid`PackagePrivate`$vPos$$ = 1, 
    TypeSystem`NestedGrid`PackagePrivate`$hPos$$ = 1, 
    TypeSystem`NestedGrid`PackagePrivate`$grid$$ = 
    DynamicModule[{
     TypeSystem`NestedGrid`PackagePrivate`renderedGrid = Deploy[
        Style[
         Grid[{{
            Item[
             Pane[
              Annotation[
               EventHandler[
                MouseAppearance[
                 Mouseover["Regge channel", 
                  Style[
                  "Regge channel", FontColor -> 
                   RGBColor[
                    0.2749633796890805, 0.536987306253161, 
                    0.791992189065661]]], "LinkHand"], {"MouseClicked", 1} :> 
                If[
                  TypeSystem`NestedGrid`PackagePrivate`checkInteractivity[
